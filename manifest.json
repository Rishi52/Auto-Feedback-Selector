{
  "manifest_version": 3,
  "name": "Auto Feedback Selector",
  "version": "1.0",
  "description": "Quickly select feedback options instantly.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auto Feedback Selector",
    "default_icon": {
      "16": "./icons/icon1.png",
      "32": "./icons/icon1.png",
      "48": "./icons/icon1.png",
      "128": "./icons/icon1.png"
    }
  },
  "icons": {
    "16": "./icons/icon1.png",
    "32": "./icons/icon1.png",
    "48": "./icons/icon1.png",
    "128": "./icons/icon1.png"
  }
}